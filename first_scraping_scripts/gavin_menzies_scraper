    def scrape_all_pages(self):
        """Main function to scrape all website pages"""
        print("Starting Gavin Menzies Website Scraping...")
        print("=" * 70)

        website_structure = self.get_website_structure()
        total_urls = sum(len(urls) for urls in website_structure.values())

        print(f"Total Website Pages: {total_urls}")
        print("=" * 70)

        successful = 0
        start_time = time.time()

        main_csv_path = os.path.join(self.base_dir, "all_pages_summary.csv")
        main_csv_data = []

        for section_name, urls in website_structure.items():
            print(f"\nSECTION: {section_name.upper()}")
            print("-" * 50)

            for idx, url in enumerate(urls, 1):
                print(f"  [{idx}/{len(urls)}] {url[:70]}...")
                folder_name = self.create_safe_name(url, section_name)

                page_number_parts = folder_name.split('_')
                page_number = '_'.join(page_number_parts[:3])

                time.sleep(1)

                result = self.scrape_single_page(url, section_name, folder_name, page_number)

                if result['success']:
                    successful += 1
                    print(f"  SUCCESS ({result.get('word_count', 0)} words, {result.get('image_count', 0)} images)")

                    main_csv_data.append({
                        'page_number': page_number,
                        'folder_name': folder_name,
                        'url': url,
                        'title': result.get('title', ''),
                        'word_count': result.get('word_count', 0),
                        'section': section_name
                    })

                    self.scrape_log.append({
                        'section': section_name,
                        'url': url,
                        'status': 'success',
                        'words': result.get('word_count', 0),
                        'images': result.get('image_count', 0)
                    })
                else:
                    print(f"  FAILED: {result.get('error', 'Unknown')}")
                    self.errors.append({
                        'section': section_name,
                        'url': url,
                        'folder_name': folder_name,
                        'error': result.get('error', 'Unknown')
                    })

                    main_csv_data.append({
                        'page_number': page_number,
                        'folder_name': folder_name,
                        'url': url,
                        'title': '',
                        'word_count': 0,
                        'section': section_name
                    })

                    self.scrape_log.append({
                        'section': section_name,
                        'url': url,
                        'status': 'failed',
                        'error': result.get('error')
                    })

        elapsed = time.time() - start_time

        print("\n" + "=" * 70)
        print(f"SCRAPING COMPLETED")
        print(f"  Successful: {successful}/{total_urls}")
        print(f"  Failed: {len(self.errors)}/{total_urls}")
        print(f"  Time: {int(elapsed / 60)}m {int(elapsed % 60)}s")
        print("=" * 70)

        self.save_main_csv(main_csv_data, main_csv_path)
        self.create_final_report(successful, total_urls, elapsed, main_csv_data)
        self.create_url_mapping_file()

        zip_path = self.create_zip_file()

        return successful, zip_path

    def scrape_single_page(self, url, section, folder_name, page_number):
        """Scrape a single URL and save as CSV and images as JPG"""
        try:
            page_dir = os.path.join(self.base_dir, section, folder_name)
            data_dir = os.path.join(page_dir, "data")
            images_dir = os.path.join(page_dir, "images")
            os.makedirs(data_dir, exist_ok=True)
            os.makedirs(images_dir, exist_ok=True)

            with sync_playwright() as p:
                browser = p.chromium.launch(headless=True)
                context = browser.new_context(
                    viewport={'width': 1920, 'height': 1080},
                    user_agent='Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
                )
                page = context.new_page()

                try:
                    print(f"    Loading page...")
                    page.goto(url, wait_until="domcontentloaded", timeout=45000)
                    page.wait_for_timeout(3000)

                    print(f"    Loading content...")
                    for _ in range(3):
                        page.evaluate("window.scrollBy(0, 800)")
                        page.wait_for_timeout(1500)

                    print(f"    Extracting data...")
                    page_data = self.extract_page_data(page, url)

                    print(f"    Downloading images...")
                    images = self.download_images(page, images_dir)
                    page_data['images'] = images
                    page_data['image_count'] = len(images)

                    page_data['scrape_timestamp'] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    page_data['page_number'] = page_number
                    page_data['folder_name'] = folder_name
                    page_data['section'] = section

                    print(f"    Creating CSV...")
                    csv_path = os.path.join(data_dir, f"{folder_name}.csv")
                    self.save_page_to_csv(page_data, csv_path, folder_name, page_number)

                    browser.close()

                    return {
                        'success': True,
                        'word_count': page_data.get('word_count', 0),
                        'image_count': len(images),
                        'title': page_data.get('title', '')
                    }

                except Exception as e:
                    error_msg = str(e)[:200]
                    print(f"    Error: {error_msg}")
                    browser.close()
                    return {'success': False, 'error': error_msg}

        except Exception as e:
            error_msg = f"Fatal error: {str(e)[:200]}"
            print(f"    Fatal error: {error_msg}")
            return {'success': False, 'error': error_msg}

    def extract_page_data(self, page, url):
        """Extract data from a webpage"""
        data = {
            'url': url,
            'title': '',
            'content': '',
            'content_length': 0,
            'word_count': 0,
            'external_links': []
        }
        try:
            data['title'] = page.title()

            content_selectors = [
                'main',
                'article',
                'div.content',
                'div.entry-content',
                'div.post-content',
                'div.article-content',
                'div.page-content',
                'div[role="main"]',
                'body'
            ]

            content_text = ""
            for selector in content_selectors:
                try:
                    element = page.query_selector(selector)
                    if element:
                        text = element.inner_text().strip()
                        if len(text) > 100:
                            content_text = text
                            break
                except:
                    continue

            if not content_text or len(content_text) < 100:
                try:
                    paragraphs = page.query_selector_all('p')
                    texts = []
                    for p in paragraphs[:50]:
                        text = p.inner_text().strip()
                        if len(text) > 30:
                            texts.append(text)
                    content_text = '\n\n'.join(texts)
                except:
                    pass

            data['content'] = self.clean_text(content_text)
            data['content_length'] = len(data['content'])
            data['word_count'] = len(data['content'].split())

            print(f"      Extracted: {data['word_count']} words")

        except Exception as e:
            print(f"      Error in extraction: {e}")

        return data

    def download_images(self, page, images_dir):
        """Download images from the page as JPG"""
        images = []

        try:
            img_selectors = [
                'img[src]',
                'img[data-src]',
                'div.gallery img',
                'article img',
                'main img',
                'img.thumbnail',
                'img.wp-image'
            ]

            found_urls = set()

            for selector in img_selectors:
                img_elements = page.query_selector_all(selector)
                for img in img_elements[:50]:
                    try:
                        src = img.get_attribute('src') or img.get_attribute('data-src')

                        if not src or src in found_urls:
                            continue

                        if any(x in src.lower() for x in
                               ['.svg', '.gif', 'icon', 'logo', 'avatar', 'placeholder', 'spacer']):
                            continue

                        if not any(
                                x in src.lower() for x in ['.jpg', '.jpeg', '.png', '.webp', 'image', 'img', 'phot']):
                            if 'http' not in src.lower():
                                continue

                        response = page.request.get(src)
                        if response.status == 200:
                            img_data = response.body()

                            img_num = len(images) + 1
                            img_filename = f"image_{img_num:03d}.jpg"
                            img_path = os.path.join(images_dir, img_filename)

                            with open(img_path, 'wb') as f:
                                f.write(img_data)

                            try:
                                pil_img = PILImage.open(BytesIO(img_data))
                                if pil_img.format != 'JPEG':
                                    rgb_img = pil_img.convert('RGB')
                                    rgb_img.save(img_path, 'JPEG', quality=85)
                                    img_data = open(img_path, 'rb').read()
                                    pil_img = PILImage.open(BytesIO(img_data))

                                images.append({
                                    'path': img_path,
                                    'filename': img_filename,
                                    'width': pil_img.width,
                                    'height': pil_img.height,
                                    'size_kb': len(img_data) / 1024,
                                    'format': pil_img.format
                                })
                            except Exception as img_error:
                                images.append({
                                    'path': img_path,
                                    'filename': img_filename,
                                    'width': 0,
                                    'height': 0,
                                    'size_kb': len(img_data) / 1024,
                                    'format': 'unknown'
                                })

                            found_urls.add(src)

                    except Exception as e:
                        continue

            print(f"      Downloaded {len(images)} images as JPG")

        except Exception as e:
            print(f"      Image download error: {e}")

        return images

    def clean_text(self, text):
        """Clean text for safe CSV storage"""
        if not text:
            return ""

        replacements = {
            '\u2022': '•',
            '\u2013': '-',
            '\u2014': '-',
            '\u2018': "'",
            '\u2019': "'",
            '\u201c': '"',
            '\u201d': '"',
            '\u00a0': ' ',
            '\u200b': '',
            '\ufffd': '',
            '\u2026': '...',
            '\u00a9': '(c)',
            '\u00ae': '(R)',
            '\u2122': '(TM)',
            '\n': ' ',
            '\r': ' ',
            '\t': ' ',
            '"': '""',
        }

        cleaned = text
        for char, replacement in replacements.items():
            cleaned = cleaned.replace(char, replacement)

        cleaned = re.sub(r'\s+', ' ', cleaned)
        return cleaned.strip()

    def save_page_to_csv(self, page_data, csv_path, folder_name, page_number):
        """Save webpage data to CSV with new column structure"""
        try:
            csv_data = {
                'page_number': page_number,
                'folder_name': folder_name,
                'url': page_data.get('url', ''),
                'title': page_data.get('title', '')[:1000],
                'word_count': page_data.get('word_count', 0),
                'section': page_data.get('section', '')
            }

            fieldnames = [
                'page_number',
                'folder_name',
                'url',
                'title',
                'word_count',
                'section'
            ]
            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                writer.writerow(csv_data)

            return True

        except Exception as e:
            print(f"      Error saving page CSV: {e}")
            return False

    def save_main_csv(self, data, csv_path):
        """Save main CSV with all pages summary"""
        try:
            os.makedirs(os.path.dirname(csv_path), exist_ok=True)

            fieldnames = [
                'page_number',
                'folder_name',
                'url',
                'title',
                'word_count',
                'section'
            ]

            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                writer.writerows(data)

            print(f"Main CSV saved: {csv_path}")
            return True

        except Exception as e:
            print(f"Error saving main CSV: {e}")
            return False

    def create_url_mapping_file(self):
        """Create a text file mapping short folder names to full URLs"""
        mapping_path = os.path.join(self.base_dir, "URL_MAPPING.txt")
        csv_path = os.path.join(self.base_dir, "url_mapping.csv")

        os.makedirs(os.path.dirname(mapping_path), exist_ok=True)

        with open(mapping_path, 'w', encoding='utf-8') as f:
            f.write("FOLDER NAME TO URL MAPPING\n")
            f.write("=" * 80 + "\n\n")
            for short_name, full_url in self.url_mapping.items():
                f.write(f"{short_name}\n  -> {full_url}\n\n")

        with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
            fieldnames = ['folder_name', 'url', 'scrape_timestamp']
            writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
            writer.writeheader()
            for short_name, full_url in self.url_mapping.items():
                writer.writerow({
                    'folder_name': short_name,
                    'url': full_url,
                    'scrape_timestamp': datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                })

        print(f"URL mapping saved: {mapping_path}")
        print(f"URL mapping CSV saved: {csv_path}")

    def create_final_report(self, successful, total, elapsed, csv_data):
        """Create comprehensive scraping report as CSV"""
        if self.errors:
            errors_csv_path = os.path.join(self.base_dir, "scraping_errors.csv")
            with open(errors_csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                fieldnames = ['section', 'url', 'folder_name', 'error', 'timestamp']
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                for err in self.errors:
                    writer.writerow({
                        'section': err['section'],
                        'url': err['url'],
                        'folder_name': err['folder_name'],
                        'error': err['error'][:500],
                        'timestamp': datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    })
            print(f"Errors CSV saved: {errors_csv_path}")

        summary_csv_path = os.path.join(self.base_dir, "scraping_summary.csv")
        with open(summary_csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
            fieldnames = [
                'total_pages',
                'successful',
                'failed',
                'success_rate',
                'time_elapsed_seconds',
                'time_elapsed_minutes',
                'date_completed'
            ]
            writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
            writer.writeheader()
            writer.writerow({
                'total_pages': total,
                'successful': successful,
                'failed': len(self.errors),
                'success_rate': f"{(successful / total * 100):.1f}%",
                'time_elapsed_seconds': int(elapsed),
                'time_elapsed_minutes': f"{int(elapsed / 60)}m {int(elapsed % 60)}s",
                'date_completed': datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            })

        print(f"Summary CSV saved: {summary_csv_path}")

        section_summary = {}
        for item in csv_data:
            section = item['section']
            if section not in section_summary:
                section_summary[section] = {'total': 0, 'success': 0, 'failed': 0}

            section_summary[section]['total'] += 1
            if item['title']:
                section_summary[section]['success'] += 1
            else:
                section_summary[section]['failed'] += 1

        section_csv_path = os.path.join(self.base_dir, "section_summary.csv")
        with open(section_csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
            fieldnames = ['section', 'total_pages', 'successful', 'failed', 'success_rate']
            writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
            writer.writeheader()

            for section, stats in section_summary.items():
                writer.writerow({
                    'section': section,
                    'total_pages': stats['total'],
                    'successful': stats['success'],
                    'failed': stats['failed'],
                    'success_rate': f"{(stats['success'] / stats['total'] * 100):.1f}%" if stats['total'] > 0 else "0%"
                })
        print(f"Section summary CSV saved: {section_csv_path}")

    def create_zip_file(self):
        """Create a zip file of all scraped content"""
        try:
            zip_path = "gavin_menzies.zip"
            with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
                for root, dirs, files in os.walk(self.base_dir):
                    for file in files:
                        file_path = os.path.join(root, file)
                        arcname = os.path.relpath(file_path, ".")
                        zipf.write(file_path, arcname)

            print(f"Zip file created: {zip_path}")
            return zip_path

        except Exception as e:
            print(f"Could not create zip file: {e}")
            return None


