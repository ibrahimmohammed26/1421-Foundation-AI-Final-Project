    def create_safe_name(self, url, section_name):
        """Create Windows-safe folder name using hash + readable prefix"""
        if section_name not in self.section_counter:
            self.section_counter[section_name] = 0
        self.section_counter[section_name] += 1

        path = urlparse(url).path.strip('/').split('/')[-1]
        if not path:
            path = urlparse(url).path.strip('/').split('/')[-2] if len(
                urlparse(url).path.strip('/').split('/')) > 1 else "index"

        readable = re.sub(r'[^\w\-]', '_', path)[:30]

        url_hash = hashlib.md5(url.encode()).hexdigest()[:8]

        section_num = section_name.split('_')[0] if '_' in section_name else "01"
        page_number = f"{section_num}_page_{self.section_counter[section_name]:03d}"
        safe_name = f"{page_number}_{url_hash}"

        self.url_mapping[safe_name] = url
        return safe_name

