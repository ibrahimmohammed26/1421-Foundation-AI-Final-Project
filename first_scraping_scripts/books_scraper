    def save_scraping_summary_csv(self, successful, total, elapsed):
        """Save scraping statistics CSV."""
        csv_path = os.path.join(self.base_dir, "scraping_summary.csv")
        try:
            os.makedirs(os.path.dirname(csv_path), exist_ok=True)

            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                fieldnames = [
                    'total_files',
                    'successful',
                    'failed',
                    'success_rate',
                    'time_elapsed',
                    'date_completed'
                ]
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                writer.writerow({
                    'total_files': total,
                    'successful': successful,
                    'failed': total - successful,
                    'success_rate': f"{(successful / total * 100):.1f}%" if total > 0 else "0%",
                    'time_elapsed': f"{int(elapsed / 60)}m {int(elapsed % 60)}s",
                    'date_completed': datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                })

            print(f"Statistics CSV saved: {csv_path}")
            return True

        except Exception as e:
            print(f"Error saving statistics CSV: {e}")
            return False

    def save_errors_csv(self):
        """Save errors CSV if any errors occurred."""
        csv_path = os.path.join(self.base_dir, "scraping_errors.csv")
        try:
            os.makedirs(os.path.dirname(csv_path), exist_ok=True)

            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
