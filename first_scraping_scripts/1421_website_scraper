class FoundationScraper:
    def __init__(self, max_workers=5):
        self.headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
            'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
        }
        self.errors = []
        self.scrape_log = []
        self.url_mapping = {}
        self.section_counter = {}
        self.page_counter = 1
        self.max_workers = max_workers
        self.lock = threading.Lock()

    def create_folder_name(self, url, section_name, title=""):
        """Create readable folder name with date prefix for archives"""
        is_archive_section = "archive" in section_name.lower()

        # Extract date from URL for archive sections
        date_prefix = ""
        if is_archive_section:
            date_match = re.search(r'/archives/(\d{2})-(\d{4})', url)
            if date_match:
                month, year = date_match.groups()
                month_names = {
                    '01': 'Jan', '02': 'Feb', '03': 'Mar', '04': 'Apr',
                    '05': 'May', '06': 'Jun', '07': 'Jul', '08': 'Aug',
                    '09': 'Sep', '10': 'Oct', '11': 'Nov', '12': 'Dec'
                }
                month_name = month_names.get(month, month)
                date_prefix = f"{month_name}_{year}_"

        # Use title or URL path
        if title and len(title) > 5:
            title_words = title.strip()
        else:
            path = urlparse(url).path.strip('/').split('/')[-1]
            if not path or len(path) < 3:
                title_words = "Archive Page" if is_archive_section else "Untitled Page"
            else:
                title_words = path.replace('.html', '').replace('.php', '').replace('-', ' ').replace('_', ' ').title()

        # Clean title
        folder_base = re.sub(r'[<>:"/\\|?*]', '_', title_words)
        folder_base = re.sub(r'\s+', ' ', folder_base).strip()

        if not folder_base or len(folder_base) < 2:
            folder_base = "Archive Page" if is_archive_section else "Web Page"

        # Truncate if too long
        max_length = 60 if is_archive_section else 80
        if len(folder_base) > max_length:
            folder_base = folder_base[:max_length - 3] + '...'

        # Thread-safe counter increment
        with self.lock:
            if section_name not in self.section_counter:
                self.section_counter[section_name] = 0
            self.section_counter[section_name] += 1
            counter = self.section_counter[section_name]

        # Section number
        section_num = section_name.split('_')[0]

        # Add date prefix for archives
        folder_name = f"{section_num}_{date_prefix}{folder_base}_{counter:02d}"

        # Add hash for uniqueness
        url_hash = hashlib.md5(url.encode()).hexdigest()[:6]
        folder_name = f"{folder_name}_{url_hash}"

        # Final cleanup
        folder_name = re.sub(r'[<>:"/\\|?*]', '_', folder_name)

        # Store mapping
        self.url_mapping[folder_name] = {
            'url': url,
            'title': title_words[:100] if title_words else '',
            'section': section_name
        }

        return folder_name

    def scrape_all_pages(self):
        """Main function with parallel processing"""
        print("🚀 Starting 1421 Foundation Website Scraping...")
        print("=" * 70)

        page_structure = self.get_page_structure()
        total_urls = sum(len(urls) for urls in page_structure.values())

        print(f"📊 Total Pages: {total_urls}")
        print(f"⚡ Max Concurrent Workers: {self.max_workers}")
        print("=" * 70)

        successful = 0
        start_time = time.time()
        main_summary_data = []

        # Process each section
        for section_name, urls in page_structure.items():
            print(f"\n📁 SECTION: {section_name.upper()}")
            print(f"   Processing {len(urls)} pages...")
            print("-" * 50)

            # Parallel processing
            with ThreadPoolExecutor(max_workers=self.max_workers) as executor:
                future_to_url = {
                    executor.submit(self.scrape_url_wrapper, url, section_name, idx): url
                    for idx, url in enumerate(urls, 1)
                }

                for future in as_completed(future_to_url):
                    url = future_to_url[future]
                    try:
                        result = future.result()

                        if result['success']:
                            successful += 1
                            print(f"  ✅ [{result['idx']}/{len(urls)}] {url[:50]}... ({result['word_count']} words)")

                            with self.lock:
                                main_summary_data.append({
                                    'page_number': self.page_counter,
                                    'folder_name': result['folder_name'],
                                    'url': url,
                                    'title': result.get('title', ''),
                                    'word_count': result.get('word_count', 0),
                                    'section': section_name
                                })

                                self.scrape_log.append({
                                    'section': section_name,
                                    'url': url,
                                    'status': 'success',
                                    'words': result.get('word_count', 0)
                                })

                                self.page_counter += 1
                        else:
                            print(
                                f"  ❌ [{result['idx']}/{len(urls)}] {url[:50]}... Failed: {result.get('error', 'Unknown')[:50]}")

                            with self.lock:
                                self.errors.append({
                                    'section': section_name,
                                    'url': url,
                                    'folder_name': result.get('folder_name', 'unknown'),
                                    'error': result.get('error', 'Unknown')
                                })

                                main_summary_data.append({
                                    'page_number': self.page_counter,
                                    'folder_name': result.get('folder_name', 'unknown'),
                                    'url': url,
                                    'title': '',
                                    'word_count': 0,
                                    'section': section_name
                                })

                                self.scrape_log.append({
                                    'section': section_name,
                                    'url': url,
                                    'status': 'failed',
                                    'error': result.get('error')
                                })

                                self.page_counter += 1

                    except Exception as e:
                        print(f"  ❌ Error processing {url[:50]}...: {str(e)[:50]}")

        elapsed = time.time() - start_time

        print("\n" + "=" * 70)
        print(f"🎉 SCRAPING COMPLETED!")
        print(f"   Successful: {successful}/{total_urls}")
        print(f"   Failed: {len(self.errors)}/{total_urls}")
        print(f"   Time: {int(elapsed / 60)}m {int(elapsed % 60)}s")
        print(f"   Speed: {total_urls / elapsed:.2f} pages/second")
        print("=" * 70)

        # Save all CSVs
        self.save_all_csvs(main_summary_data, successful, total_urls, elapsed)

        # Create zip file
        zip_path = self.create_zip_file()

        return successful, zip_path

    def scrape_url_wrapper(self, url, section_name, idx):
        """Wrapper for parallel scraping"""
        time.sleep(random.uniform(0.5, 1.5))
        temp_folder_name = self.create_folder_name(url, section_name, "")
        result = self.scrape_single_url(url, section_name, temp_folder_name)
        result['idx'] = idx
        return result

    def scrape_single_url(self, url, section, folder_name):
        """Scrape a single URL and save as CSV"""
        try:
            base_dir = "1421_foundation_scraped"

            # Try requests first
            try:
                response = requests.get(url, headers=self.headers, timeout=30)
                response.raise_for_status()
                soup = BeautifulSoup(response.text, 'html.parser')
            except Exception as e:
                print(f"    ⚠️ Requests failed, trying Playwright: {str(e)[:80]}")
                soup = self.scrape_playwright(url)

            # Extract content
            title = self.clean_text(self.extract_title(soup, url))
            content = self.clean_text(self.extract_content(soup))
            author = self.extract_author(soup)

            # Extract date for archive sections
            date_found = ""
            if "archive" in section.lower():
                date_match = re.search(r'/(\d{2})-(\d{4})/', url)
                if date_match:
                    month, year = date_match.groups()
                    date_found = f"{year}-{month}-01"

            word_count = len(content.split()) if content else 0

            # Update folder name with actual title
            folder_name = self.create_folder_name(url, section, title)

            # Create folder structure
            page_dir = os.path.join(base_dir, section, folder_name)
            data_dir = os.path.join(page_dir, "data")
            os.makedirs(data_dir, exist_ok=True)

            # Create CSV data
            csv_data = {
                'page_number': self.section_counter[section],
                'folder_name': folder_name,
                'url': url,
                'title': title[:1000] if title else 'No Title',
                'content': content[:50000] if content else 'No Content',
                'author': author[:200] if author else '',
                'word_count': word_count,
                'date': date_found
            }

            # Save CSV
            csv_path = os.path.join(data_dir, f"{folder_name}.csv")
            success = self.save_page_to_csv(csv_data, csv_path)

            if success:
                return {
                    'success': True,
                    'word_count': word_count,
                    'title': title,
                    'folder_name': folder_name
                }
            else:
                return {'success': False, 'error': 'Failed to save CSV', 'folder_name': folder_name}

        except Exception as e:
            error_msg = str(e)[:200]
            if 'folder_name' not in locals() or not folder_name:
                folder_name = self.create_folder_name(url, section, "Failed Page")
            return {'success': False, 'error': error_msg, 'folder_name': folder_name}

    def save_all_csvs(self, summary_data, successful, total, elapsed):
        """Save all CSV files"""
        print("\n💾 Saving all CSV files...")
        self.save_summary_csv(summary_data)
        self.save_url_mapping_csv()
        self.save_scraping_summary_csv(successful, total, elapsed)
        self.save_section_summary_csv(summary_data)
        if self.errors:
            self.save_errors_csv()

    def save_summary_csv(self, data):
        """Save main summary CSV"""
        csv_path = "1421_foundation_scraped/all_pages_summary.csv"
        try:
            os.makedirs(os.path.dirname(csv_path), exist_ok=True)
            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                fieldnames = ['page_number', 'folder_name', 'url', 'title', 'word_count', 'section']
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                writer.writerows(data)
            print(f"✅ Main summary CSV saved: {csv_path}")
            return True
        except Exception as e:
            print(f"❌ Error saving main summary CSV: {e}")
            return False

    def save_url_mapping_csv(self):
        """Save URL mapping CSV"""
        csv_path = "1421_foundation_scraped/url_mapping.csv"
        try:
            os.makedirs(os.path.dirname(csv_path), exist_ok=True)
            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                fieldnames = ['folder_name', 'url', 'title']
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                for folder_name, info in self.url_mapping.items():
                    writer.writerow({
                        'folder_name': folder_name,
                        'url': info['url'],
                        'title': info['title']
                    })
            print(f"✅ URL mapping CSV saved: {csv_path}")
            return True
        except Exception as e:
            print(f"❌ Error saving URL mapping CSV: {e}")
            return False

    def save_scraping_summary_csv(self, successful, total, elapsed):
        """Save scraping summary CSV"""
        csv_path = "1421_foundation_scraped/scraping_summary.csv"
        try:
            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                fieldnames = ['total_pages', 'successful', 'failed', 'success_rate', 'time_elapsed_minutes',
                              'date_completed']
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                writer.writerow({
                    'total_pages': total,
                    'successful': successful,
                    'failed': len(self.errors),
                    'success_rate': f"{(successful / total * 100):.1f}%",
                    'time_elapsed_minutes': f"{int(elapsed / 60)}m {int(elapsed % 60)}s",
                    'date_completed': datetime.now().strftime("%Y-%m-%d")
                })
            print(f"✅ Scraping summary CSV saved: {csv_path}")
            return True
        except Exception as e:
            print(f"❌ Error saving scraping summary CSV: {e}")
            return False

    def save_section_summary_csv(self, summary_data):
        """Save section summary CSV"""
        csv_path = "1421_foundation_scraped/section_summary.csv"
        try:
            section_stats = {}
            for item in summary_data:
                section = item['section']
                if section not in section_stats:
                    section_stats[section] = {'total': 0, 'success': 0, 'failed': 0}
                section_stats[section]['total'] += 1
                if item['word_count'] > 0:
                    section_stats[section]['success'] += 1
                else:
                    section_stats[section]['failed'] += 1

            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                fieldnames = ['section', 'total_pages', 'successful', 'failed', 'success_rate']
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                for section, stats in section_stats.items():
                    writer.writerow({
                        'section': section,
                        'total_pages': stats['total'],
                        'successful': stats['success'],
                        'failed': stats['failed'],
                        'success_rate': f"{(stats['success'] / stats['total'] * 100):.1f}%" if stats[
                                                                                                   'total'] > 0 else "0%"
                    })
            print(f"✅ Section summary CSV saved: {csv_path}")
            return True
        except Exception as e:
            print(f"❌ Error saving section summary CSV: {e}")
            return False

    def save_errors_csv(self):
        """Save errors CSV"""
        csv_path = "1421_foundation_scraped/scraping_errors.csv"
        try:
            with open(csv_path, 'w', newline='', encoding='utf-8-sig') as csvfile:
                fieldnames = ['section', 'url', 'folder_name', 'error']
                writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                writer.writeheader()
                for err in self.errors:
                    writer.writerow({
                        'section': err['section'],
                        'url': err['url'],
                        'folder_name': err['folder_name'],
                        'error': err['error'][:500]
                    })
            print(f"✅ Errors CSV saved: {csv_path}")
            return True
        except Exception as e:
            print(f"❌ Error saving errors CSV: {e}")
            return False

